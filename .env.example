# yorgos.ai environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file with real secrets.

# ---------------------------------------------------------------------------
# AI processing (server-only)
# Required for POST /api/ai/review and POST /api/ai/cmd.
# When missing, those routes return 503 no_api_key.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Email sending via Resend (server-only)
# Required for POST /api/email/send-offer to send real emails.
# When missing, that route returns 503 missing_email_config.
# EMAIL_FROM: the configured sender address.
# EMAIL_REPLY_TO: optional reply-to address. Leave blank to omit.
# ---------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=

# ---------------------------------------------------------------------------
# Supabase (Backend Phase 1+)
# Not required for the localStorage MVP. Required once backend is active.
#
# NEXT_PUBLIC_SUPABASE_URL: your Supabase project URL.
# Safe to expose to the browser because it uses the NEXT_PUBLIC_ prefix.
#
# NEXT_PUBLIC_SUPABASE_ANON_KEY: the public anon key for your project.
# Safe to expose to the browser. Supabase Row Level Security enforces access.
#
# SUPABASE_SERVICE_ROLE_KEY: the service role admin key.
# SERVER-ONLY. Never use NEXT_PUBLIC_ prefix on this variable.
# Never import this in client components or browser-side code.
# Bypasses Row Level Security. Use only in trusted server API routes.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Live demo Option 2: call -> recording -> transcription -> brief -> Viber intake
# ---------------------------------------------------------------------------

# Public app URL used when generating customer intake links.
# Local example: http://localhost:3000
# Vercel example: https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=

# ---------------------------------------------------------------------------
# OpenAI transcription and call brief generation (server-only)
# Required for live call recording transcription and AI brief.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_BRIEF_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Apifon Viber sending (server-only)
# Required for automatic Viber intake message after a new inbound lead.
# Uses Apifon OAuth client credentials.
# Use real values only in .env.local / Vercel env, never in this file.
# ---------------------------------------------------------------------------
APIFON_BASE_URL=
APIFON_CLIENT_ID=
APIFON_API_KEY=
APIFON_SENDER_ID=
APIFON_VIBER_SENDER_ID=
APIFON_WEBHOOK_SECRET=

